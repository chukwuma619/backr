# Next.js / Backr app — copy to .env for local dev.
# On Vercel (or Railway): set the same keys in the service UI.

# Database
DATABASE_URL=

# Auth
SESSION_SECRET=

# Fiber (payments)
# Patrons each set their own node URL in Dashboard → Basic (see /fiber-setup).
# Platform fee node — must be reachable from this Next.js server (private URL OK if co-hosted).
PLATFORM_FIBER_RPC_URL=http://127.0.0.1:8227
# More Fiber keys: /fiber-setup
# FIBER_INVOICE_CURRENCY=Fibt
# FIBER_PAYMENT_POLL_INTERVAL_MS=800
# FIBER_PAYMENT_MAX_WAIT_MS=120000
# FIBER_SEND_PAYMENT_TIMEOUT_SECONDS=120
# FIBER_SEND_PAYMENT_MAX_FEE_AMOUNT_HEX=0x...
# FIBER_SEND_PAYMENT_MAX_FEE_RATE=5
# FIBER_SEND_PAYMENT_MAX_PARTS=8
# FIBER_SEND_PAYMENT_HOP_HINTS=[{"pubkey":"0x..."}]
# FIBER_INVOICE_API_ENABLED=false

# Cron (renewals — /api/cron/renewals)
CRON_SECRET=

# Platform fee (default 5% if unset)
PLATFORM_FEE_PERCENT=5

PINATA_JWT=
NEXT_PUBLIC_GATEWAY_URL=

# Encrypts per-post AES keys for paid post bodies (32 bytes: openssl rand -base64 32)
POST_CONTENT_MASTER_KEY=
