# Copy to apps/web/.env for local dev, or set the same keys on Vercel (Root Directory: apps/web).
# Platform / patron Fiber Docker: see docker/fiber-node/.env.example

# Database
DATABASE_URL=

# Auth
SESSION_SECRET=

# Fiber (payments).
# Patrons must each set their own node URL in Dashboard → Basic settings (see /fiber-setup).
# Platform Fiber node (5% fee). Example: https://your-fnn.up.railway.app (must be reachable from the Next.js server).
PLATFORM_FIBER_RPC_URL=http://127.0.0.1:8227

# Cron (renewals)
CRON_SECRET=

# Platform fee (default 5% if not set)
PLATFORM_FEE_PERCENT=5

PINATA_JWT=
NEXT_PUBLIC_GATEWAY_URL=

# Encrypts per-post AES keys for paid post bodies (32 bytes: openssl rand -base64 32)
POST_CONTENT_MASTER_KEY=
